# ============================================================
#  Multi-Turn AI Chatbot — Environment Variables
#  Copy this file to .env and fill in your actual values
# ============================================================

# ── Groq API (LLaMA 3) ──────────────────────────────────────
# Free API key from https://console.groq.com
# No credit card required. Starts with: gsk_...
GROQ_API_KEY=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
# Model to use. Options:
#   llama-3.1-8b-instant       fast, recommended for development
#   llama-3.3-70b-versatile    smarter, slower
GROQ_MODEL=llama-3.1-8b-instant

# ── Google OAuth 2.0 ────────────────────────────────────────
# Get from: https://console.cloud.google.com
# APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=947194633536-mbph3llsn3teei9k2e52886crk77nf47.apps.googleusercontent.com

GOOGLE_CLIENT_SECRET=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

# Must match EXACTLY what you set in Google Console
# Local:  http://localhost:5000/auth/callback
# Colab:  https://xxxx-ngrok.io/auth/callback  (update after tunnel starts)
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/callback

# ── Flask App ────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change-this-to-a-random-secret-string
FLASK_ENV=development
APP_PORT=5000

# ── SQLite Database ──────────────────────────────────────────
# Path to the SQLite file. Will be created automatically.
DATABASE_PATH=chatbot.db
